# Postgres + Azure storage config

# Where Postgres is running. Default: localhost on the standard port.
# If you use a managed Postgres, put its host here.
PG_HOST=localhost
PG_PORT=5432
PG_DB=ducklake_catalog

# Postgres admin user used by the seed script (must exist with CREATEDB).
# init.sql creates the four demo logins (alice/bob/carol/admin) on top of this.
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=postgres

# ─── Azure Blob Storage ────────────────────────────────────────────────
# Create a Storage Account in the Azure portal, then go to
# "Security + networking → Access keys" and copy the storage account
# name and key1. Create a blob container (e.g. "ducklake-data").
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

# Final DATA_PATH the DuckLake will use. Should be az://<container>/.
DATA_PATH=az://ducklake-data/
